# AIRPG 環境變數設定範本
# 將此檔案複製並重新命名為 .env，填入對應設定
# 若使用 Launcher 控制台 (localhost:8080)，設定將由介面自動管理

# --- LLM 對話模型設定 ---
# 供應商選項: ollama / openai / anthropic / google
LLM_MODE=ollama

# 模型名稱 (依供應商不同而異)
# Ollama    -> llama3 / mistral / gemma3 ...
# OpenAI    -> gpt-4o / gpt-4o-mini ...
# Anthropic -> claude-3-5-sonnet-20241022 ...
# Google    -> gemini-2.0-flash ...
LLM_MODEL_NAME=llama3

# --- 各供應商 API Key (選用，在地 Ollama 不需要) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- 向量嵌入模型設定 ---
# 供應商選項: ollama / openai / google
EMBED_MODE=ollama

# 嵌入模型名稱
# Ollama -> nomic-embed-text
# OpenAI -> text-embedding-3-small
# Google -> models/embedding-001
EMBED_MODEL_NAME=nomic-embed-text

# 注意：切換 EMBED_MODE 後須重新執行知識庫 Ingest，向量資料將被清除重建。

# --- 選填：Godot Web 遊戲靜態檔路徑 ---
# 未設定時後端預設使用專案根目錄的 dist/。Docker 會設為 /app/static/game。
# GAME_STATIC_PATH=/app/static/game
